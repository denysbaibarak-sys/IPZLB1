# Публикация веб-результата
*.[Pp]ublish.xml
*.azurePubxml
# Примечание: Закомментируйте следующую строку, если хотите проверить настройки развертывания веб-приложения.
# Однако строки подключения к базе данных (с потенциальными паролями) будут незашифрованы.
*.pubxml
*.publishproj

# Настройки публикации веб-приложения Microsoft Azure. Закомментируйте следующую строку, если хотите...
# Проверьте настройки публикации вашего веб-приложения Azure, но конфиденциальная информация не будет содержаться.
# В этих скриптах будут незашифрованные данные
PublishScripts/

# Пакеты NuGet
*.nupkg
# Пакеты символов NuGet
*.snupkg
# Папку packages можно игнорировать из-за функции восстановления пакетов.
**/[Pp]ackages/*
# за исключением build/, который используется в качестве цели MSBuild.
!**/[Pp]ackages/build/
# Раскомментируйте при необходимости, однако, как правило, комментарий будет сгенерирован заново при необходимости.
#!**/[Pp]ackages/repositories.config
# Файлы project.json в NuGet v3 создают больше файлов, которые можно игнорировать.
*.nuget.props
*.nuget.targets

# Результаты сборки Microsoft Azure
csx/
*.build.csdef

# Эмулятор Microsoft Azure
ecf/
rcf/

# Каталоги и файлы пакетов приложений Windows Store
AppPackages/
BundleArtifacts/
Package.StoreAssociation.xml
_pkginfo.txt
*.appx
*.appxbundle
*.appxupload

# Файлы кэша Visual Studio
