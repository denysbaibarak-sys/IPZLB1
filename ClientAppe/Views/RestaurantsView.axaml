<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             xmlns:m="using:ClientAppe.Models"
             x:Class="ClientAppe.Views.RestaurantsView"
             x:DataType="vm:RestaurantsViewModel">

	<DockPanel Background="#F7F9FC">
		<Border DockPanel.Dock="Top" Background="White" Height="70" BoxShadow="0 20 20 0 #05000000">
			<Grid ColumnDefinitions="Auto, *, Auto" Margin="30,0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="🏠" Margin="0,0,10,0" VerticalAlignment="Center"/>
					<TextBlock Text="FoodHub" FontSize="20" FontWeight="ExtraBold" Foreground="#5849E8"/>
				</StackPanel>

				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
					<Button Content="Головна" Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>

					<Button Content="Профіль" Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>

					<Button Content="Замовлення" Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToOrdersCommand}"/>

					<TextBlock Text="🛒" VerticalAlignment="Center" Cursor="Hand"/>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer>
			<StackPanel Margin="40">
				<TextBlock Text="Ресторани" FontSize="32" FontWeight="Bold" Foreground="#1A1A1A"/>
				<TextBlock Text="{Binding FoundCountText, FallbackValue='Знайдено 3 закладів'}"
						   Foreground="#94A3B8" Margin="0,5,0,25"/>

				<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,15">
					<Button Content="Всі заклади" Classes="filterBtn"/>
					<Button Content="🍴 Ресторани" Classes="filterBtn active"/>
					<Button Content="🍔 Фаст-фуд" Classes="filterBtn"/>
					<Button Content="✨ Інше" Classes="filterBtn"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,30">
					<Button Content="Популярні" Classes="sortBtn active"/>
					<Button Content="За рейтингом" Classes="sortBtn"/>
					<Button Content="Швидка доставка" Classes="sortBtn"/>
				</StackPanel>

				<ItemsControl ItemsSource="{Binding Restaurants}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel Orientation="Horizontal"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="m:RestaurantModel">
							<Border Width="350" Margin="0,0,25,25" CornerRadius="20" Background="White" BoxShadow="0 10 20 0 #10000000">
								<StackPanel>
									<Panel Height="200">
										<Border CornerRadius="20,20,0,0" Background="#E2E8F0">
											<TextBlock Text="🖼️" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40"/>
										</Border>
										<Border Background="#FF6B00" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" Padding="12,5">
											<TextBlock Text="Популярне" Foreground="White" FontSize="11" FontWeight="Bold"/>
										</Border>
									</Panel>

									<StackPanel Margin="20">
										<TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
										<TextBlock Text="Ресторан" Foreground="#94A3B8" Margin="0,2,0,15"/>

										<StackPanel Orientation="Horizontal" Spacing="15">
											<StackPanel Orientation="Horizontal" Spacing="5">
												<TextBlock Text="⭐" Foreground="#FACC15"/>
												<TextBlock Text="{Binding Rating}" FontWeight="Bold"/>
											</StackPanel>
											<StackPanel Orientation="Horizontal" Spacing="5">
												<TextBlock Text="🕒" Foreground="#94A3B8"/>
												<TextBlock Text="{Binding DeliveryTime}" Foreground="#64748B"/>
											</StackPanel>
										</StackPanel>

										<Separator Background="#F1F5F9" Margin="0,15"/>

										<TextBlock Text="Графік роботи: 08:00 - 22:00" FontSize="12" Foreground="#94A3B8"/>
									</StackPanel>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</ScrollViewer>
	</DockPanel>

	<UserControl.Styles>
		<Style Selector="Button.navLink">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#64748B"/>
			<Setter Property="FontSize" Value="14"/>
			<Setter Property="FontWeight" Value="Medium"/>
		</Style>

		<Style Selector="Button.filterBtn">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="15,8"/>
			<Setter Property="CornerRadius" Value="10"/>
		</Style>
		<Style Selector="Button.filterBtn.active">
			<Setter Property="Background" Value="#1A202C"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>

		<Style Selector="Button.sortBtn">
			<Setter Property="Background" Value="White"/>
			<Setter Property="Padding" Value="15,6"/>
			<Setter Property="CornerRadius" Value="8"/>
			<Setter Property="FontSize" Value="13"/>
		</Style>
		<Style Selector="Button.sortBtn.active">
			<Setter Property="Background" Value="#1A202C"/>
			<Setter Property="Foreground" Value="White"/>
		</Style>
	</UserControl.Styles>
</UserControl>