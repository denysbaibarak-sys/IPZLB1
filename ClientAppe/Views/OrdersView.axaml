<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             xmlns:m="using:ClientAppe.Models"
             x:Class="ClientAppe.Views.OrdersView"
             x:DataType="vm:OrdersViewModel">

	<DockPanel Background="#F7F9FC">
		<Border DockPanel.Dock="Top" Background="White" Height="70" BoxShadow="0 2 10 0 #10000000">
			<Grid ColumnDefinitions="Auto, *, Auto" Margin="30,0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="🏠" Margin="0,0,10,0" VerticalAlignment="Center"/>
					<TextBlock Text="FoodHub" FontSize="20" FontWeight="ExtraBold" Foreground="#5849E8"/>
				</StackPanel>

				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
					<Button Content="Головна"
							Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>

					<Button Content="Профіль"
							Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>

					<Button Content="Замовлення" Classes="navLink active" Background="#EEF2FF" Foreground="#5849E8"/>
					<TextBlock Text="🛒" VerticalAlignment="Center" Cursor="Hand"/>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer>
			<StackPanel Margin="60,40" MaxWidth="1000" HorizontalAlignment="Stretch">
				<TextBlock Text="Мої замовлення" FontSize="32" FontWeight="Bold" Margin="0,0,0,30"/>

				<Border Background="#F1F5F9" CornerRadius="12" Padding="5" Margin="0,0,0,30">
					<UniformGrid Columns="2">
						<Button Content="Мої замовлення (4)" Classes="tabBtn active"/>
						<Button Content="Історія замовлень (0)" Classes="tabBtn"/>
					</UniformGrid>
				</Border>

				<ItemsControl ItemsSource="{Binding Orders}">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="m:OrderModel">
							<Border Background="White" CornerRadius="18" Margin="0,0,0,20" Padding="25" BoxShadow="0 5 15 0 #08000000">
								<Grid RowDefinitions="Auto, Auto, 1, Auto">
									<Grid ColumnDefinitions="*, Auto">
										<TextBlock Text="{Binding RestaurantName}" FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>

										<Border Grid.Column="1" Background="#FFF7ED" CornerRadius="12" Padding="12,6">
											<StackPanel Orientation="Horizontal" Spacing="8">
												<Ellipse Width="8" Height="8" Fill="#F97316"/>
												<TextBlock Text="{Binding Status}" Foreground="#F97316" FontSize="13" FontWeight="SemiBold"/>
											</StackPanel>
										</Border>
									</Grid>

									<TextBlock Grid.Row="1" Text="{Binding ItemsSummary}" Foreground="#64748B" Margin="0,10,0,20"/>

									<Separator Grid.Row="2" Background="#F1F5F9"/>

									<Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
										<TextBlock Text="{Binding OrderDate}" Foreground="#94A3B8" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" Text="{Binding TotalPrice, StringFormat='\{0\} грн'}"
												   FontSize="20" FontWeight="Bold" Foreground="#1A1A1A"/>
									</Grid>
								</Grid>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<StackPanel IsVisible="False" HorizontalAlignment="Center" Margin="0,50" Spacing="15">
					<TextBlock Text="🛍️" FontSize="60" HorizontalAlignment="Center"/>
					<TextBlock Text="Немає замовлень" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
					<TextBlock Text="Тут поки що порожньо." Foreground="#94A3B8" HorizontalAlignment="Center"/>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>
	</DockPanel>

	<UserControl.Styles>
		<Style Selector="Button.navLink">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Padding" Value="15,8"/>
			<Setter Property="CornerRadius" Value="8"/>
		</Style>

		<Style Selector="Button.tabBtn">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Foreground" Value="#64748B"/>
			<Setter Property="Padding" Value="0,12"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="HorizontalAlignment" Value="Stretch"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
		</Style>
		<Style Selector="Button.tabBtn.active /template/ ContentPresenter">
			<Setter Property="Background" Value="White"/>
			<Setter Property="BoxShadow" Value="0 2 8 0 #10000000"/>
			<Setter Property="CornerRadius" Value="10"/>
		</Style>

		<Style Selector="Button.tabBtn.active">
			<Setter Property="Foreground" Value="#1A1A1A"/>
		</Style>
	</UserControl.Styles>
</UserControl>