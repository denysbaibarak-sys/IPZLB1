<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             x:Class="ClientAppe.Views.ProfileView"
             x:DataType="vm:ProfileViewModel">

    <DockPanel Background="#F7F9FC">
<Border DockPanel.Dock="Top" Background="White" Height="70" BoxShadow="0 2 10 0 #10000000">
    <Grid ColumnDefinitions="Auto, *, Auto" Margin="30,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border Width="40" Height="40" Background="#5849E8" CornerRadius="10" Margin="0,0,10,0">
                <PathIcon Data="{StaticResource home_regular}" Foreground="White" Width="20" Height="20"/>
            </Border>
            <TextBlock Text="FoodHub" FontSize="22" FontWeight="ExtraBold" Foreground="#1A1A1A" VerticalAlignment="Center"/>
        </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="25" VerticalAlignment="Center">
                    <Button Content="Головна" Classes="navLink" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>
                    <Button Content="Профіль" Classes="navLink" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>
                    <Button Content="Замовлення" Classes="navLink" Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToOrdersCommand}"/>
                    
                    <Button Background="#F1F5F9" Padding="12,8" CornerRadius="10" Cursor="Hand"
                            Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToCartCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Кошик" Foreground="#1A1A1A" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
    </Grid>
</Border>

        <Grid ColumnDefinitions="300, *" Margin="40">
            <Border Grid.Column="0" Background="White" CornerRadius="20" Padding="15" VerticalAlignment="Top" BoxShadow="0 5 15 0 #08000000">
                <StackPanel Spacing="5">
                    <Button Classes="menuBtn active">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource person_regular}" Width="18"/>
                            <TextBlock Text="Профіль" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="menuBtn">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource mail_regular}" Width="18"/>
                            <TextBlock Text="Повідомлення" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Background="#F1F5F9" Margin="5,15"/>

                    <Button Classes="menuBtn logout" Command="{Binding LogoutCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <PathIcon Data="{StaticResource arrow_reply_regular}" Width="18" Foreground="#EF4444"/>
                            <TextBlock Text="Вийти з акаунту" Foreground="#EF4444" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="30,0,0,0" Background="White" CornerRadius="20" Padding="40" BoxShadow="0 5 15 0 #08000000">
                <StackPanel Spacing="35">
                    <Grid ColumnDefinitions="*, Auto">
                        <TextBlock Text="Профіль" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                        <Button Grid.Column="1" Content="Редагувати" Classes="editBtn"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="25">
                        <Border Width="100" Height="100" CornerRadius="50" Background="#5849E8" BoxShadow="0 8 20 0 #305849E8">
                            <TextBlock Text="{Binding UserInitial}" Foreground="White" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding User.Login}" FontSize="26" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock Text="{Binding User.RegistrationDate, StringFormat='З нами з \{0\}'}" Foreground="#94A3B8" FontSize="14" Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Separator Background="#F1F5F9"/>

                    <StackPanel Spacing="20">
                        <Border Classes="infoField">
                            <StackPanel>
                                <TextBlock Text="Email" Classes="fieldLabel"/>
                                <TextBlock Text="{Binding User.Email}" Classes="fieldValue"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="infoField">
                            <StackPanel>
                                <TextBlock Text="Телефон" Classes="fieldLabel"/>
                                <TextBlock Text="{Binding User.Phone}" Classes="fieldValue"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="infoField">
                            <StackPanel>
                                <TextBlock Text="Адреса доставки" Classes="fieldLabel"/>
                                <TextBlock Text="{Binding User.Address}" Classes="fieldValue"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>

    <UserControl.Styles>
        <Style Selector="Button.navLink">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>
        <Style Selector="Button.navLink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#5849E8"/>
        </Style>

        <Style Selector="Button.menuBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Foreground" Value="#64748B"/>
        </Style>
        <Style Selector="Button.menuBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#5849E8"/>
        </Style>
        <Style Selector="Button.menuBtn.active /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="Foreground" Value="#5849E8"/>
        </Style>

        <Style Selector="Border.infoField">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="25,18"/>
        </Style>
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style Selector="TextBlock.fieldValue">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style Selector="Button.editBtn">
            <Setter Property="Background" Value="#5849E8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.editBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
</UserControl>