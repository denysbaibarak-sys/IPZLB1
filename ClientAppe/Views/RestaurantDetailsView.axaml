<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ClientAppe.ViewModels"
             xmlns:m="using:ClientAppe.Models"
             x:Class="ClientAppe.Views.RestaurantDetailsView"
             x:DataType="vm:RestaurantDetailsViewModel">

	<DockPanel Background="#F7F9FC">
		<Border DockPanel.Dock="Top" Background="White" Height="70" BoxShadow="0 2 10 0 #10000000">
			<Grid ColumnDefinitions="Auto, *, Auto" Margin="30,0">
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<TextBlock Text="🏠" Margin="0,0,10,0" VerticalAlignment="Center"/>
					<TextBlock Text="FoodHub" FontSize="20" FontWeight="ExtraBold" Foreground="#5849E8"/>
				</StackPanel>

				<StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
					<Button Content="Головна" Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToHomeCommand}"/>

					<Button Content="Профіль" Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToProfileCommand}"/>

					<Button Content="Замовлення" Classes="navLink"
							Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).NavigateToOrdersCommand}"/>

					<Panel>
						<TextBlock Text="🛒" VerticalAlignment="Center" FontSize="20" Cursor="Hand"/>
						<Border Background="#5849E8" CornerRadius="10" Width="18" Height="18"
								HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10,-5,0,0">
							<TextBlock Text="2" Foreground="White" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</Panel>
				</StackPanel>
			</Grid>
		</Border>

		<ScrollViewer>
			<StackPanel>
				<Panel Height="300">
					<Image Source="avares://ClientAppe/Assets/restaurant_bg.jpg" Stretch="UniformToFill"/>
					<Border>
						<Border.Background>
							<LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
								<GradientStop Offset="0" Color="#CC000000"/>
								<GradientStop Offset="1" Color="#00000000"/>
							</LinearGradientBrush>
						</Border.Background>
					</Border>

					<StackPanel VerticalAlignment="Bottom" Margin="40" Spacing="10">
						<TextBlock Text="Пузата Хата" FontSize="36" FontWeight="Bold" Foreground="White"/>
						<TextBlock Text="Справжня українська домашня кухня. Гарячі борщі, вареники та ситні м'ясні страви."
								   Foreground="#E2E8F0" FontSize="16" MaxWidth="800" TextWrapping="Wrap"/>

						<StackPanel Orientation="Horizontal" Spacing="20" Margin="0,10,0,0">
							<StackPanel Orientation="Horizontal" Spacing="5">
								<TextBlock Text="⭐" Foreground="#FACC15"/>
								<TextBlock Text="4.8" Foreground="White" FontWeight="Bold"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="5">
								<TextBlock Text="🕒" Foreground="#E2E8F0"/>
								<TextBlock Text="30-45 хв" Foreground="White"/>
							</StackPanel>
							<StackPanel Orientation="Horizontal" Spacing="5">
								<TextBlock Text="📍" Foreground="#E2E8F0"/>
								<TextBlock Text="1.2 км" Foreground="White"/>
							</StackPanel>
						</StackPanel>
					</StackPanel>
				</Panel>

				<ItemsControl ItemsSource="{Binding Categories}" Margin="40,30,40,10">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="15"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Content="{Binding}" Classes="categoryTab"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<ItemsControl ItemsSource="{Binding MenuItems}" Margin="40,20">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<WrapPanel/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>

					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="m:FoodModel">
							<Border Width="380" Margin="0,0,25,25" Background="White" CornerRadius="20" BoxShadow="0 8 20 0 #08000000">
								<StackPanel>
									<Border Height="200" CornerRadius="20,20,0,0" Background="#F1F5F9" ClipToBounds="True">
										<TextBlock Text="🍲" FontSize="50" HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Border>

									<StackPanel Margin="20" Spacing="10">
										<TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/>
										<TextBlock Text="{Binding Description}" Foreground="#94A3B8" FontSize="13" TextWrapping="Wrap" Height="40"/>

										<Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
											<TextBlock Text="{Binding Price, StringFormat='\{0\} грн'}" FontSize="20" FontWeight="Bold" Foreground="#5849E8" VerticalAlignment="Center"/>

											<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
												<Button Content="+" Classes="addBtn"
														Command="{Binding $parent[UserControl].((vm:RestaurantDetailsViewModel)DataContext).AddToCartCommand}"
														CommandParameter="{Binding}"/>
											</StackPanel>
										</Grid>
									</StackPanel>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</StackPanel>
		</ScrollViewer>
	</DockPanel>

	<UserControl.Styles>
		<Style Selector="Button.navLink">
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>

		<Style Selector="Button.categoryTab">
			<Setter Property="Background" Value="White"/>
			<Setter Property="Padding" Value="25,12"/>
			<Setter Property="CornerRadius" Value="12"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="BorderBrush" Value="#E2E8F0"/>
		</Style>

		<Style Selector="Button.addBtn">
			<Setter Property="Background" Value="#1A202C"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Padding" Value="20,8"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="FontWeight" Value="Bold"/>
		</Style>
	</UserControl.Styles>
</UserControl>